# ======================================

# Unity .gitignore

# ======================================

# This .gitignore is suitable for most Unity projects.

# It keeps assets and project settings but ignores generated files.

############################

# OS Generated Files

############################
.DS_Store
Thumbs.db
Desktop.ini

############################

# Unity Generated Folders

############################
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Mm]emoryCaptures/
UserSettings/

############################

# Unity Cache Server

############################
/Cache/

############################

# Visual Studio / Rider

############################
.vs/
.idea/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

############################

# Mono / Debug

############################
*.exe
*.dll
*.apk
*.aab
*.unitypackage
*.app

############################

# Crash Logs

############################
sysinfo.txt

############################

# Build Output

############################
*.apk
*.aab
*.unitypackage
*.app
*.ipa

############################

# Addressables

############################
/ServerData

############################

# Generated Lighting

############################
[Bb]akedAssets/

############################

# Rider

############################
.idea/

############################

# Gradle

############################
.gradle/

############################

# Temporary AutoGenerated Files

############################
ExportedObj/
.consulo/
*.log

############################

# Unity Collaborate

############################
.collab/

############################

# Ignore Local Packages Cache

############################
/Library/PackageCache/

############################

# Ignore test results

############################
TestResults/

############################

# Ignore coverage reports

############################
Coverage/

############################

# Unity Cloud Build

############################
/build/

############################

# Ignore Addressable Builds

############################
/Assets/StreamingAssets/aa/

############################

# Ignore IDE configs

############################
*.DotSettings.user
